VITE_DASHSCOPE_API_KEY=
VITE_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_DASHSCOPE_MODEL=qwen-plus
VITE_DEV_CHAT_PROXY_TARGET=

# Vercel serverless function
DASHSCOPE_API_KEY=

# Mode 0: proxy to your own chatbot hosted elsewhere
# Example: http://47.97.222.168/api/chat
CHATBOT_PROXY_URL=
CHATBOT_PROXY_TOKEN=

# Mode A: call a Qwen model through the server proxy
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Mode B: call your Bailian app/chatbot through app_id
# If DASHSCOPE_APP_ID is set, the proxy will prefer app mode.
DASHSCOPE_APP_ID=
DASHSCOPE_WORKSPACE=

# Optional custom site assistant prompt
DASHSCOPE_SYSTEM_PROMPT=
